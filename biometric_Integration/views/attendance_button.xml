<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="fetch_biometric_attendance_data_inlist" model="ir.ui.view">
        <field name="name">hr.attendance</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.view_attendance_tree" />
        <field name="arch" type="xml">
            <xpath expr="//list/header" position="inside">
                 <button class="btn-secondary" string="Fetch Biometric Attendance" name="import_biometric_data" type="object"/>
            </xpath>

            <xpath expr="//list/field[@name='check_out']" position="after">
                <field name="device_name" optional="hidden"/>
                <field name="machine_name" optional="hidden"/>
            </xpath>
        </field>
    </record>

    
    <record id="newfetch_biometric_attendance_inlist" model="ir.ui.view">
        <field name="name">hr.attendance</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_employee_simple_tree_view" />
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='check_out']" position="after">
                <field name="device_name" optional="hidden"/>
                <field name="machine_name" optional="hidden"/>
            </xpath>
        </field>
    </record>
</odoo>
